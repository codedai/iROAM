# ─── Database ───────────────────────────────────────────────────────────────
# Used by the API, collector, dashboard, and Alembic. The Postgres server
# must have PostGIS available — in docker-compose we use postgis/postgis:16-3.4.
DATABASE_URL=postgresql+psycopg://ttc:ttc@postgres:5432/ttc_gtfsrt

# For local (non-docker) runs, point at the host-exposed port from docker-compose:
# DATABASE_URL=postgresql+psycopg://ttc:ttc@localhost:5433/ttc_gtfsrt

# ─── TTC Realtime feeds ─────────────────────────────────────────────────────
# VehiclePositions is the canonical MVP feed. ?format=binary pins the
# efficient protobuf wire format. Without it, TTC serves human-readable
# protobuf text (~7x larger) which is fine for inspection but wasteful as
# the ingestion path.
GTFS_RT_VEHICLE_POSITIONS_URL=https://gtfsrt.ttc.ca/vehicles/position?format=binary

# Inspection-only URL (parser can decode this too, via text-format fallback):
#   https://gtfsrt.ttc.ca/vehicles/position?format=text

# Reserved for future milestones; currently unused.
GTFS_RT_TRIP_UPDATES_URL=https://gtfsrt.ttc.ca/trips/update?format=binary
GTFS_RT_ALERTS_URL=https://gtfsrt.ttc.ca/alerts?format=binary

# ─── Collector ──────────────────────────────────────────────────────────────
# How often the collector polls the feed, in seconds. TTC vehicles typically
# update every ~20 s.
COLLECTOR_INTERVAL_SECONDS=20
# Per-request HTTP timeout.
COLLECTOR_HTTP_TIMEOUT_SECONDS=10
# Retries for transient errors (connect, 5xx, timeout).
COLLECTOR_HTTP_RETRIES=2
# User-Agent advertised to the TTC feed.
COLLECTOR_USER_AGENT=ttc-gtfsrt-platform/0.2 (+https://github.com/example/ttc-gtfsrt)

# ─── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# CORS origins ("*" for dev; comma-separated list in prod).
API_CORS_ORIGINS=*

# ─── Dashboard (Streamlit) ──────────────────────────────────────────────────
DASHBOARD_API_BASE_URL=http://api:8000
# When running streamlit locally: DASHBOARD_API_BASE_URL=http://localhost:8000

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true

# ─── Tuning knobs ───────────────────────────────────────────────────────────
# How recently a vehicle must have been observed to count as "active".
ACTIVE_VEHICLE_WINDOW_MINUTES=5
# Max rows returned by any paginated endpoint (hard cap).
MAX_PAGE_SIZE=5000
